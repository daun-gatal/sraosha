# Copy to .sraosha:  cp .sraosha.example .sraosha
# Resolution: --config, SRAOSHA_CONFIG, ./.sraosha, ~/.sraosha — env vars override this file.
# Every key below matches SraoshaSettings in sraosha/config.py (same names as environment variables).

# --- Database & broker ---
DATABASE_URL=postgresql+asyncpg://sraosha:sraosha@localhost:5432/sraosha
REDIS_URL=redis://localhost:6379/0

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=
CORS_ALLOWED_ORIGINS=*

# --- Contracts (defaults for YAML / engine) ---
CONTRACTS_DIR=./contracts
DEFAULT_ENFORCEMENT_MODE=block

# --- Slack alerting (SlackAlerter; requires SLACK_ENABLED=true and webhook) ---
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

# --- Email alerting (EmailAlerter; requires EMAIL_ENABLED=true and SMTP_*) ---
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# --- Connection credential encryption (set in production; empty uses dev-only key) ---
ENCRYPTION_KEY=
